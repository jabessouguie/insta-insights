# ===================================
# InstaInsights - Environment Variables
# ===================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# ─── AI Provider Configuration ─────────────────────────────────────────────
# The app auto-detects the provider from available API keys (Anthropic > OpenAI > Gemini).
# Explicit override (optional): gemini | anthropic | openai | openai-compatible
# AI_PROVIDER=gemini

# Optional model override (uses provider default if not set)
# Examples: gemini-2.5-pro, claude-opus-4-6, gpt-4o-mini, llama3
# AI_MODEL=

# Google Gemini (default) — https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Anthropic Claude — https://console.anthropic.com/
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI — https://platform.openai.com/
# OPENAI_API_KEY=your_openai_api_key_here

# OpenAI-compatible / self-hosted (Ollama, Together.ai, Mistral, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1

# Optional: Path to Instagram data (defaults to ../data relative to webapp/)
# INSTAGRAM_DATA_PATH=/absolute/path/to/instagram/export

# GitLab Bug Report Integration
# GITLAB_URL defaults to https://gitlab.com if not set
# GITLAB_PROJECT_ID can be a numeric ID (e.g. 12345678) or a namespaced path (e.g. mygroup/myproject)
# GITLAB_URL=https://gitlab.com
# GITLAB_TOKEN=your_gitlab_personal_access_token
# GITLAB_PROJECT_ID=your_project_id_or_path

# App Config
NEXT_PUBLIC_APP_NAME=InstaInsights
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Public URL for SEO metadata (sitemap, OG images)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── PostHog Analytics ──────────────────────────────────────────────────────
# Leave empty to disable analytics (safe for local dev)
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_POSTHOG_HOST=https://eu.posthog.com

# ─── Sentry Error Monitoring ────────────────────────────────────────────────
# Leave empty to disable Sentry (safe for local dev)
# NEXT_PUBLIC_SENTRY_DSN=https://xxx@oXXXXX.ingest.sentry.io/XXXXXXX
# SENTRY_DSN=https://xxx@oXXXXX.ingest.sentry.io/XXXXXXX
# SENTRY_AUTH_TOKEN=your_sentry_auth_token_for_source_maps

# ─── Meta / Facebook App (Instagram Graph API) ──────────────────────────────
# Required for verifying the Data Deletion Callback signed_request signature.
# Found in: Meta for Developers → Your App → Settings → Basic → App Secret
# FACEBOOK_APP_SECRET=your_facebook_app_secret_here
