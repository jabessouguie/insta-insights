# ===================================
# InstaInsights - Environment Variables
# ===================================
# Copy this file to .env.local and fill in the values
# NEVER commit .env.local to version control

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: Path to Instagram data (defaults to ../data relative to webapp/)
# INSTAGRAM_DATA_PATH=/absolute/path/to/instagram/export

# App Config
NEXT_PUBLIC_APP_NAME=InstaInsights
NEXT_PUBLIC_APP_URL=http://localhost:3000
